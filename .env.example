# Copie para `.env` na raiz do projeto e preencha com os valores do Firebase Console.
# O Expo carrega `EXPO_PUBLIC_*` a partir de `.env` ou `.env.local`, não deste arquivo.
# Reinicie o Metro após alterar: `npx expo start --clear`
#
# Builds EAS (APK preview): as mesmas variáveis estão em eas.json (perfis preview/production).
# Documentação completa: docs/eas-build-secrets.md

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
